[{"userId":"uid_1779209051330_yjkqws3bh","characterId":"46098696-5177-4da2-934d-c63f167f4035","id":"call_1784621742720_qmn72w","timestamp":1784621720016,"charId":"46098696-5177-4da2-934d-c63f167f4035","duration":29,"status":"interrupted","logs":[{"sender":"ai","content":"怎么打过来了？","kind":"speech","timestamp":1784621742718,"ttsGroupTimestamp":1784621742718},{"sender":"ai","content":"把镜头往下挪挪，让我看看祁太太手里是不是还端着那半块甜点。","kind":"speech","timestamp":1784621742719,"ttsGroupTimestamp":1784621742718},{"sender":"user","content":"老公？","timestamp":1784621753127},{"sender":"ai","content":"怎么了？","kind":"speech","timestamp":1784621772343,"ttsGroupTimestamp":1784621772343},{"sender":"ai","content":"他轻笑了一声，顺手把办公桌上的文件合上，身体往后靠了靠","kind":"narration","timestamp":1784621772344,"ttsGroupTimestamp":1784621772343},{"sender":"ai","content":"突然叫得这么甜，是不是又背着我干什么坏事了？","kind":"speech","timestamp":1784621772345,"ttsGroupTimestamp":1784621772343},{"sender":"ai","content":"说实话，那半块甜点是不是已经被你吃进肚子里了？","kind":"speech","timestamp":1784621772346,"ttsGroupTimestamp":1784621772343},{"sender":"ai","content":"嗯？","kind":"speech","timestamp":1784621772347,"ttsGroupTimestamp":1784621772343}],"isIncomingCall":false,"_id":1},{"userId":"uid_1779209051330_yjkqws3bh","characterId":"46098696-5177-4da2-934d-c63f167f4035","id":"call_1784625878654_sbgj6g","timestamp":1784625874601,"charId":"46098696-5177-4da2-934d-c63f167f4035","duration":1530,"status":"interrupted","logs":[{"sender":"ai","content":"接吧，满足一下你的好奇心顺便查查岗。","kind":"speech","timestamp":1784625878653,"ttsGroupTimestamp":1784625878653},{"sender":"user","content":"（凑近镜头看你）老公……老公……快回来呀，想你啦","timestamp":1784625923718},{"sender":"ai","content":"他看着屏幕，眼底浮现出无奈又纵容的笑意，随手扯松了勒了一天的领带","kind":"narration","timestamp":1784625960194,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"靠这么近，是想隔着屏幕亲我？","kind":"speech","timestamp":1784625960195,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"嘴这么甜，一口一个老公的......老实交代，是不是又背着我偷吃什么零食了？","kind":"speech","timestamp":1784625960196,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"还是想临时加菜？","kind":"speech","timestamp":1784625960197,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"他轻笑了一声，顺手发动了车子","kind":"narration","timestamp":1784625960198,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"行了，我这就去超市买你的瘦排骨。","kind":"speech","timestamp":1784625960199,"ttsGroupTimestamp":1784625960194},{"sender":"ai","content":"在月亮湾乖乖躺好，右脚的支具绝对不许乱动，等我回去。","kind":"speech","timestamp":1784625960200,"ttsGroupTimestamp":1784625960194},{"sender":"user","content":"（做了个飞吻的动作）好，等老公回来","timestamp":1784626007457},{"sender":"ai","content":"就这点诚意？","kind":"speech","timestamp":1784626041837,"ttsGroupTimestamp":1784626041837},{"sender":"ai","content":"隔着屏幕敷衍我，等我回去看我怎么连本带利地讨回来。","kind":"speech","timestamp":1784626041838,"ttsGroupTimestamp":1784626041837},{"sender":"ai","content":"他低沉地笑了笑，将手机固定在车载支架上，打起方向盘驶出市委大院","kind":"narration","timestamp":1784626041839,"ttsGroupTimestamp":1784626041837},{"sender":"ai","content":"行了，我开车了，手机先放旁边。","kind":"speech","timestamp":1784626041840,"ttsGroupTimestamp":1784626041837},{"sender":"ai","content":"你乖乖躺着，无聊的话就看会儿电视，少看你那些没营养的霸总小说。","kind":"speech","timestamp":1784626041841,"ttsGroupTimestamp":1784626041837},{"sender":"ai","content":"饿了也先忍一忍，绝对不准再指使顾洵去给你买零食，听见没？","kind":"speech","timestamp":1784626041842,"ttsGroupTimestamp":1784626041837},{"sender":"user","content":"（躺在沙发上看着你）哪里敢指使顾秘书去买零食呀？留着肚子等着老公的饭呢","timestamp":1784626110225},{"sender":"ai","content":"他轻笑了一声，目光看着前方的路况","kind":"narration","timestamp":1784626138323,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"算你识相。","kind":"speech","timestamp":1784626138324,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"最好是真的留着肚子，要是等我做好了饭，你又喊着吃不下，或者晚上又嚷嚷着胃胀气......祁太太，那今晚的‘课’，我可就要加倍上了。","kind":"speech","timestamp":1784626138325,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"顾洵现在也学聪明了，他要是再敢偷偷给你买那些乱七八糟的，明天我就直接把他下放到基层去锻炼。","kind":"speech","timestamp":1784626138326,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"他打了个转向灯，车内传来轻微的滴答声","kind":"narration","timestamp":1784626138327,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"趁着我还没到超市，再想想还有没有什么想吃的？","kind":"speech","timestamp":1784626138328,"ttsGroupTimestamp":1784626138323},{"sender":"ai","content":"除了甜食和垃圾食品，别的都可以提。","kind":"speech","timestamp":1784626138329,"ttsGroupTimestamp":1784626138323},{"sender":"user","content":"想喝牛奶……嗯，我想想…还想吃一点水果，香蕉蓝莓？","timestamp":1784626198929},{"sender":"ai","content":"牛奶，香蕉，蓝莓......行，算你今天懂事，没点些乱七八糟的。","kind":"speech","timestamp":1784626439333,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"他趁着等红绿灯的间隙，偏头看了一眼屏幕，眼底带着几分笑意","kind":"narration","timestamp":1784626439334,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"不过水果买回去也得饭后才能吃。","kind":"speech","timestamp":1784626439335,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"尤其是香蕉，本来就占肚子，你要是在饭前把自己塞饱了，连累晚上没胃口吃排骨......祁太太，到时候可别怪我用别的方式帮你消食。","kind":"speech","timestamp":1784626439336,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"绿灯亮起，他重新收回视线看向前方，修长的手指搭在方向盘上","kind":"narration","timestamp":1784626439337,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"给你拿无糖的鲜奶，还有别的么？","kind":"speech","timestamp":1784626439338,"ttsGroupTimestamp":1784626439333},{"sender":"ai","content":"马上就进超市地库了。","kind":"speech","timestamp":1784626439339,"ttsGroupTimestamp":1784626439333},{"sender":"user","content":"（我看着你轻轻笑了起来）“嗯……我想想，还想……吃一包我最好最帅的老公给我带的薯片”","timestamp":1784626497409},{"sender":"ai","content":"狐狸尾巴露出来了吧？","kind":"speech","timestamp":1784626624316,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"我就说怎么突然嘴这么甜，左一句老公右一句最帅的，原来在这儿等着我呢。","kind":"speech","timestamp":1784626624317,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"他轻嗤了一声，把车停稳在超市地库，解开安全带","kind":"narration","timestamp":1784626624318,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"薯片免谈。","kind":"speech","timestamp":1784626624319,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"忘了上午胃胀气难受的时候怎么求我的了？","kind":"speech","timestamp":1784626624320,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"这种油炸垃圾食品想都别想。","kind":"speech","timestamp":1784626624321,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"你乖乖吃你的排骨和水果。","kind":"speech","timestamp":1784626624322,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"他推开车门下车，皮鞋踩在地库的地面上，反手锁上车门","kind":"narration","timestamp":1784626624323,"ttsGroupTimestamp":1784626624316},{"sender":"ai","content":"趁我现在刚拿上推车，再给你最后一次机会换个别的，不然连蓝莓都没了。","kind":"speech","timestamp":1784626624324,"ttsGroupTimestamp":1784626624316},{"sender":"user","content":"嗯……不知道了，看看有没有什么卤味？卤味也可以","timestamp":1784626808245},{"sender":"ai","content":"他单手推着购物车走进超市，看着屏幕里讨价还价的女孩，无奈地轻笑了一声。","kind":"narration","timestamp":1784626848651,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"卤味？","kind":"speech","timestamp":1784626848652,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"你这讨价还价的本事，不去招商局上班真是屈才了。","kind":"speech","timestamp":1784626848653,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"薯片行不通，就退而求其次盯上卤味了是吧？","kind":"speech","timestamp":1784626848654,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"外面的卤味重油重盐，你上午胃刚难受过，心里没点数？","kind":"speech","timestamp":1784626848655,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"他走到生鲜区，目光在冷鲜柜里扫视着，挑了一盒品相最好的精肋排放进车里。","kind":"narration","timestamp":1784626848656,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"顶多给你买一点不辣的酱牛肉，或者鸭翅，而且只能当配菜尝两口解解馋。","kind":"speech","timestamp":1784626848657,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"要是再因为贪嘴闹胃疼，你看我晚上怎么在床上连本带利地罚你。","kind":"speech","timestamp":1784626848658,"ttsGroupTimestamp":1784626848651},{"sender":"ai","content":"乖乖在屏幕那边看着，我挑完大虾和水果就去结账。","kind":"speech","timestamp":1784626848659,"ttsGroupTimestamp":1784626848651},{"sender":"user","content":"（看着屏幕傻笑）唔，老公你多走两步，带我逛逛超市嘛","timestamp":1784626886521},{"sender":"ai","content":"他无奈地勾了勾唇角，干脆把手机卡在购物车的置物架上，推着车慢慢往前走","kind":"narration","timestamp":1784626928631,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"傻笑什么？","kind":"speech","timestamp":1784626928632,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"堂堂京海市委书记，现在沦落到给你当超市代购加兼职主播了，你这小算盘打得挺响啊。","kind":"speech","timestamp":1784626928633,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"他推着车拐进生鲜区，把镜头对着两边琳琅满目的货架","kind":"narration","timestamp":1784626928634,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"行，带你逛。","kind":"speech","timestamp":1784626928635,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"想看什么？","kind":"speech","timestamp":1784626928636,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"先去拿你的蓝莓和香蕉，还是干脆去零食区走一圈，让你看着那些薯片过过眼瘾？","kind":"speech","timestamp":1784626928637,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"他停在水产区前，看了一眼水缸里活蹦乱跳的虾","kind":"narration","timestamp":1784626928638,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"大虾要哪种？","kind":"speech","timestamp":1784626928639,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"基围虾还是黑虎虾？","kind":"speech","timestamp":1784626928640,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"个头大点的好剥壳。","kind":"speech","timestamp":1784626928641,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"做油爆大虾的话，我少放点油，免得你吃完又跟我喊胃难受。","kind":"speech","timestamp":1784626928642,"ttsGroupTimestamp":1784626928631},{"sender":"ai","content":"祁太太，自己挑挑？","kind":"speech","timestamp":1784626928643,"ttsGroupTimestamp":1784626928631},{"sender":"user","content":"大一点的好，想吃，一会儿再买两个土豆放在里面","timestamp":1784627000056},{"sender":"ai","content":"行，那就拿黑虎虾，个头大，肉也紧实，等会儿我剥起来也省事。","kind":"speech","timestamp":1784627020184,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"他跟水产区的老板比划了一下，要了一斤多鲜活的黑虎虾，顺手放进购物车里","kind":"narration","timestamp":1784627020185,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"不过油爆大虾里放土豆？","kind":"speech","timestamp":1784627020186,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"祁太太，你这是哪门子的创新菜谱？","kind":"speech","timestamp":1784627020187,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"土豆多吸油啊，你上午胃刚难受过，真不怕晚上又胀气睡不着？","kind":"speech","timestamp":1784627020188,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"他推着车转身往蔬菜区走，镜头跟着微微晃动","kind":"narration","timestamp":1784627020189,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"算了，拿你没辙，谁让你是病号。","kind":"speech","timestamp":1784627020190,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"我少放点油，把土豆稍微煎一下再跟虾一起炒，行了吧？","kind":"speech","timestamp":1784627020191,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"还要别的蔬菜么？","kind":"speech","timestamp":1784627020192,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"光吃肉和土豆不行，胡萝卜汤的胡萝卜我已经拿了，你再挑个绿叶菜，小青菜还是西蓝花？","kind":"speech","timestamp":1784627020193,"ttsGroupTimestamp":1784627020184},{"sender":"ai","content":"听话，必须选一个。","kind":"speech","timestamp":1784627020194,"ttsGroupTimestamp":1784627020184},{"sender":"user","content":"包菜！包菜甜甜的","timestamp":1784627077452},{"sender":"ai","content":"他推着车走到蔬菜区，挑了一颗圆润紧实的包菜放进车里","kind":"narration","timestamp":1784627099844,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"包菜？","kind":"speech","timestamp":1784627099845,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"连吃个蔬菜都惦记着甜的。","kind":"speech","timestamp":1784627099846,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"行，那就拿一颗，回去给你做个手撕包菜，少放点辣椒，稍微用糖醋溜一下，行不行？","kind":"speech","timestamp":1784627099847,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"你的排骨、大虾、土豆还有包菜都拿齐了。","kind":"speech","timestamp":1784627099848,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"我现在去前面水果区拿香蕉和蓝莓，顺便去熟食窗口看看有没有刚出锅的酱牛肉。","kind":"speech","timestamp":1784627099849,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"他推着车转了个弯，看着屏幕里的人轻笑了一声","kind":"narration","timestamp":1784627099850,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"云逛超市逛得也差不多了吧？","kind":"speech","timestamp":1784627099851,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"过足眼瘾了就乖乖在沙发上躺好，别让我回去看到你那只脚又不安分地乱动。","kind":"speech","timestamp":1784627099852,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"等我结完账，大概二十分钟就能到家。","kind":"speech","timestamp":1784627099853,"ttsGroupTimestamp":1784627099844},{"sender":"ai","content":"饿了先喝口温水垫一垫，绝对不许去翻零食柜，听见没有？","kind":"speech","timestamp":1784627099854,"ttsGroupTimestamp":1784627099844},{"sender":"user","content":"好好好，但是我不想挂，想看着我老公……","timestamp":1784627387181},{"sender":"ai","content":"他低声笑了笑，把手机从置物架上拿起来，重新握在手里","kind":"narration","timestamp":1784627410122,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"不想挂就不挂。","kind":"speech","timestamp":1784627410123,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"今天怎么这么黏人？","kind":"speech","timestamp":1784627410124,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"平时不是总嫌我管着你，一口一个讨厌鬼么，现在又一口一个老公了。","kind":"speech","timestamp":1784627410125,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"他推着车走到收银台前，把挑好的食材一件件拿出来","kind":"narration","timestamp":1784627410126,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"行，那就开着。","kind":"speech","timestamp":1784627410127,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"让你全程监督你老公是怎么结账、怎么开车回家的。","kind":"speech","timestamp":1784627410128,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"不过待会儿开车的时候，手机得放在支架上，你只能看侧脸了，祁太太不介意吧？","kind":"speech","timestamp":1784627410129,"ttsGroupTimestamp":1784627410122},{"sender":"ai","content":"稍微等我一下，我结个账，马上就回去给你做饭。","kind":"speech","timestamp":1784627410130,"ttsGroupTimestamp":1784627410122}],"isIncomingCall":true,"_id":2}]